const services=[['⌂','Real Estate Sales','Buyer and seller representation offered through Cornerstone Realty, LLC.'],['▣','Staging','Property preparation and presentation support designed to highlight key features.'],['▧','Photography','Professional listing and property photography for stronger marketing.'],['⌁','Drone Mapping','Aerial imagery, mapping, and visual documentation for properties and land.'],['↗','Investment Support','Property research and practical opportunity evaluation.']];
