---
import Layout from '../layouts/Layout.astro';
const services=[['✈','Aircraft Brokerage','Buyer and seller representation for aircraft transactions.'],['↔','Flight Brokering','Private charter sourcing through properly certificated operators.'],['⌕','Aircraft Sourcing','Market research and targeted domestic or international aircraft searches.'],['☑','Acquisition Support','Evaluation coordination, negotiation support, and transaction management.'],['◎','Aviation Consulting','Practical guidance for aircraft ownership and mission requirements.']];
---
<Layout active="aerial" title="Aerial Operations | Legion Services LLC" description="Flight brokering, aircraft brokerage, sourcing, and aviation transaction support.">
<section class="page-hero"><div class="wrap page-hero-inner"><div><div class="eyebrow">Legion Services LLC</div><h1>Aerial Operations</h1><h2>Professional aircraft brokerage. Personal service.</h2><p>We help clients source private flights, buy or sell aircraft, evaluate opportunities, and navigate aviation transactions with discretion and clear communication.</p><div class="actions"><a class="btn" href="mailto:legionserviceswv@gmail.com?subject=Aerial%20Operations%20Inquiry">Discuss Your Needs</a><a class="btn outline" href="tel:+13045901434">Call (304) 590-1434</a></div></div><div class="hero-art">✈</div></div></section>
<section class="section"><div class="wrap"><div class="section-head"><div class="eyebrow">Aviation Services</div><h2>Access, guidance, and transaction support.</h2></div><div class="services">{services.map(([i,t,d])=><article class="service"><div class="icon">{i}</div><h3>{t}</h3><p>{d}</p></article>)}</div></div></section>
<section class="section dark-band"><div class="wrap split"><div><div class="eyebrow">Experience. Discretion. Results.</div><h2>Mission-first aviation support.</h2><p>Every aviation request is different. We begin with your mission, timing, passenger needs, budget, and operating priorities, then help identify practical solutions.</p></div><div class="stat-panel"><div class="stat">Aircraft buyer representation</div><div class="stat">Aircraft seller representation</div><div class="stat">Private flight sourcing</div><div class="stat">Acquisition coordination</div></div></div></section>
<section class="section"><div class="wrap split"><div class="hero-art" style="min-height:330px">◈</div><div><div class="eyebrow">Important Charter Disclosure</div><h2>Flights arranged through qualified operators.</h2><p>Legion Services LLC does not operate aircraft as an air carrier. When assisting with private charter, transportation is provided by independent FAA-certificated direct air carriers that retain operational control of the flight.</p><div class="notice">Aircraft availability, operator approval, pricing, and itinerary are subject to confirmation. Brokerage and consulting services do not replace independent legal, tax, maintenance, or pre-purchase inspection advice.</div></div></div></section>
<section class="contact-band"><div class="wrap"><div><b style="font-size:24px">Ready to elevate your journey?</b><br />Speak with us about flight sourcing or an aircraft transaction.</div><a class="btn outline" href="mailto:legionserviceswv@gmail.com?subject=Aerial%20Operations%20Inquiry">Contact Us</a></div></section>
</Layout>
