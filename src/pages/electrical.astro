---
import Layout from '../layouts/Layout.astro';
const services=[['⚡','Commercial Electrical','Power distribution, lighting, service upgrades, and tenant improvements.'],['▥','Industrial Electrical','Equipment power, controls, facility upgrades, and troubleshooting.'],['★','Government Solutions','Professional support for public-sector and government facilities.'],['🔧','Maintenance & Repairs','Preventive maintenance, diagnostics, repair, and modernization.'],['◷','Emergency Response','Responsive support when critical electrical systems fail.']];
---
<Layout active="electrical" title="Electrical Division | Legion Services LLC" description="Commercial, industrial, and government electrical contracting in West Virginia.">
<section class="page-hero"><div class="wrap page-hero-inner"><div><div class="eyebrow">Legion Services LLC</div><h1>Electrical Division</h1><h2>Powering what matters. Built to perform.</h2><p>Professional electrical contracting for commercial, industrial, and government clients—from routine installations to complex infrastructure, energy systems, maintenance, and emergency response.</p><div class="actions"><a class="btn" href="mailto:legionserviceswv@gmail.com?subject=Electrical%20Service%20Request">Request Service</a><a class="btn outline" href="tel:+13045901434">Call (304) 590-1434</a></div></div><div class="hero-art">⚡</div></div></section>
<section class="section"><div class="wrap"><div class="section-head"><div class="eyebrow">Our Electrical Services</div><h2>Built for demanding environments.</h2></div><div class="services">{services.map(([i,t,d])=><article class="service"><div class="icon">{i}</div><h3>{t}</h3><p>{d}</p></article>)}</div></div></section>
<section class="section dark-band"><div class="wrap brand-strip"><div><div class="eyebrow">Trusted energy systems</div><h2>Generator and energy installation capability.</h2><p>Legion Services installs and supports Cummins and Generac generator systems and Tesla energy products. Product availability, authorization requirements, permits, and project eligibility are confirmed for each installation.</p><div class="brand-names"><span class="brand-pill">CUMMINS</span><span class="brand-pill">GENERAC</span><span class="brand-pill">TESLA ENERGY</span></div></div><div class="stat-panel"><div class="stat"><b>WV</b>Licensed electrical contractor</div><div class="stat"><b>24/7</b>Emergency response availability</div><div class="stat"><b>3</b>Core client sectors</div><div class="stat"><b>1</b>Accountable team</div></div></div></section>
<section class="section"><div class="wrap split"><div><div class="eyebrow">Commercial • Industrial • Government</div><h2>Safety, documentation, and execution.</h2><p>Our approach centers on planning, code compliance, quality workmanship, and clear communication from scope review through closeout.</p></div><div class="stat-panel"><div class="stat">Commercial build-outs</div><div class="stat">Industrial facilities</div><div class="stat">Government buildings</div><div class="stat">Generators and backup power</div></div></div></section>
<section class="contact-band"><div class="wrap"><div><b style="font-size:24px">Need electrical service?</b><br />We are ready to help protect, power, and improve your facility.</div><a class="btn outline" href="mailto:legionserviceswv@gmail.com?subject=Electrical%20Service%20Request">Request Service</a></div></section>
</Layout>
